# =============================================================================
# Copy this file to .env and fill in your own values
# Generate secrets with: openssl rand -hex 32
# =============================================================================

# Kafka (internal network, no changes needed)
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Symbols to track (comma-separated, lowercase Binance pairs)
SYMBOLS=btcusdt,ethusdt,solusdt,adausdt,dotusdt,bchusdt,qntusdt

# InfluxDB
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=CHANGE_ME_run_openssl_rand_hex_32
INFLUXDB_ORG=crypto-analytics
INFLUXDB_BUCKET=crypto
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=CHANGE_ME_run_openssl_rand_hex_32

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_use_a_strong_password

# Alert thresholds (percentage)
ALERT_THRESHOLD_5M=2.0
ALERT_THRESHOLD_15M=5.0
RSI_PERIOD=14
