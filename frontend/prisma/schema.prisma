datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  password       String?
  image          String?
  provider       String?
  dashboardCoins String?
  settings       String?
  createdAt      DateTime @default(now())
}
